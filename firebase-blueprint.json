{
  "entities": {
    "StoryboardProject": {
      "title": "Storyboard Project",
      "description": "A saved storyboard project containing multiple frames and metadata.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who owns this project." },
        "name": { "type": "string", "description": "The name of the storyboard project." },
        "input": { "type": "string", "description": "The original script or input text used to generate the storyboard." },
        "frames": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "frame_description": { "type": "string" },
              "visual_url": { "type": "string" },
              "annotation": { "type": "string" }
            },
            "required": ["frame_description"]
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "collaborators": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of user UIDs who have collaborator access."
        }
      },
      "required": ["userId", "name", "input", "frames", "createdAt", "updatedAt"]
    },
    "Character": {
      ...
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information stored in Firestore.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "email": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "email", "updatedAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A feedback comment on a project.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "authorName", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profiles."
    },
    "/storyboards/{storyboardId}": {
      "schema": "StoryboardProject",
      "description": "Collection of saved storyboard projects."
    },
    "/storyboards/{storyboardId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a specific storyboard."
    },
    "/characters/{characterId}": {
      "schema": "Character",
      "description": "Collection of saved character profiles."
    }
  }
}
