rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: storyboards
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - Owner UID
    //   - name: string (required) - Project name (1-100 chars)
    //   - input: string (required) - Original script (1-5000 chars)
    //   - frames: list (required) - Array of StoryboardFrame objects (max 20)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // Collection: pastTrends
    // Document ID: trends-{timestamp}
    // Fields:
    //   - userId: string (required) - Owner UID
    //   - trends: list (required) - Array of Trend objects (max 20)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isCollaborator() {
      return isAuthenticated() && (resource.data.userId == request.auth.uid || (resource.data.collaborators != null && request.auth.uid in resource.data.collaborators));
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['displayName', 'email', 'updatedAt']) &&
             data.displayName is string && data.displayName.size() > 0 &&
             data.email is string &&
             data.updatedAt is timestamp;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'text', 'createdAt']) &&
             data.authorId == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isValidUserProfile(request.resource.data);
    }

    match /storyboards/{storyboardId} {
      allow read: if isAuthenticated() && isCollaborator();
      allow create: if isAuthenticated() && 
                      isOwner(request.resource.data.userId) && 
                      isValidStoryboard(request.resource.data);
      allow update: if isAuthenticated() && 
                      isCollaborator() && 
                      isValidStoryboard(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && isDocOwner();

      match /comments/{commentId} {
        allow read: if isAuthenticated() && isCollaborator();
        allow create: if isAuthenticated() && 
                        get(/databases/$(database)/documents/storyboards/$(storyboardId)).data.userId != null &&
                        (get(/databases/$(database)/documents/storyboards/$(storyboardId)).data.userId == request.auth.uid || 
                         request.auth.uid in get(/databases/$(database)/documents/storyboards/$(storyboardId)).data.collaborators) &&
                        isValidComment(request.resource.data);
        allow delete: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isDocOwner());
      }
    }

    match /pastTrends/{trendId} {
      allow read: if isAuthenticated() && isDocOwner();
      allow create: if isAuthenticated() && 
                      isOwner(request.resource.data.userId) && 
                      isValidPastTrend(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /characters/{characterId} {
      allow read: if isAuthenticated() && isDocOwner();
      allow create: if isAuthenticated() && 
                      isOwner(request.resource.data.userId) && 
                      isValidCharacter(request.resource.data);
      allow update: if isAuthenticated() && 
                      isDocOwner() && 
                      isOwner(request.resource.data.userId) && 
                      isValidCharacter(request.resource.data) &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && isDocOwner();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
